# Notion Configuration
# Get token: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=your_database_id_here

# Optional
CUDA_DEVICE=0
LOG_LEVEL=INFO
WHISPER_MODEL=small
DISABLE_NOTION=0
ENABLE_TRANSCRIPT_CLEANING=1

# Provider Mode: local | cloud | hybrid
# local  — Whisper + Ollama (default, no API key needed)
# cloud  — OpenAI Whisper API + OpenAI Chat Completions
# hybrid — local first, cloud fallback on failure
PROVIDER_MODE=local

# LLM Model (local mode, Ollama)
# Primary model used for summarization.
LLM_MODEL=qwen3.5:latest

# Optional fallback when the primary model fails or is unavailable.
LLM_MODEL_FALLBACK=qwen2.5:7b-instruct-q4_K_M

# Cloud API (cloud / hybrid mode)
# OPENAI_API_KEY=sk-xxxxxxxxxx
# OPENAI_BASE_URL=               # Leave blank for api.openai.com; set for Azure / proxy
# OPENAI_MODEL=gpt-4o-mini       # Chat model for summarization
# OPENAI_WHISPER_MODEL=whisper-1  # Speech-to-text model
